 #matricula
import pandas as pd
import matplotlib.pyplot as plt
 
df = pd.read_csv("estudiantes.csv")
 
plt.scatter(df["Matricula"], df["Calificacion_Final"])
plt.xlabel("Matricula")
plt.ylabel("Calificación final")
plt.title("matricula vs Calificación final")
plt.show()
